                    </span>
                    <button onClick={() => onRemoverAnexo(caso.id, a.id)} className="text-stone-300 hover:text-red-500">
                      <Trash2 className="h-3.5 w-3.5" />
                    </button>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

