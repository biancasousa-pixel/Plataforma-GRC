/* ------------------------------ utilidades ------------------------------ */

let uidSeq = 0;
function uid(prefixo) {
  uidSeq += 1;
  return `${prefixo}-${Date.now().toString(36)}-${uidSeq}`;
}

function iso(diasOffset = 0) {
  const d = new Date();
  d.setDate(d.getDate() + diasOffset);
  return d.toISOString();
}

function formatarData(valor) {
  if (!valor) return "—";
  const d = new Date(valor);
  if (Number.isNaN(d.getTime())) return "—";
  return d.toLocaleDateString("pt-BR");
}

function tempoRelativo(valorIso) {
  if (!valorIso) return "—";
  const diffMs = Date.now() - new Date(valorIso).getTime();
  const min = Math.floor(diffMs / 60000);
  if (min < 1) return "agora";
  if (min < 60) return `há ${min} min`;
  const h = Math.floor(min / 60);
  if (h < 24) return `há ${h}h`;
  const d = Math.floor(h / 24);
  if (d < 30) return `há ${d}d`;
  const mo = Math.floor(d / 30);
  return `há ${mo} ${mo > 1 ? "meses" : "mês"}`;
}

function diasAte(dataStr) {
  if (!dataStr) return null;
  const alvo = new Date(dataStr);
  const hoje = new Date();
  alvo.setHours(0, 0, 0, 0);
  hoje.setHours(0, 0, 0, 0);
  return Math.round((alvo - hoje) / 86400000);
}

function calcularPrazoCaso(caso, slaConfig) {
  const regra = slaConfig.find((s) => s.categoria === caso.categoria);
  const dias = regra ? regra.prazoDias : 30;
  const d = new Date(caso.dataRecebimento);
  d.setDate(d.getDate() + dias);
  return d.toISOString();
}

function calcularProximaRevisao(dataUltimaRevisao, cicloMeses) {
  if (!dataUltimaRevisao || !cicloMeses) return null;
  const d = new Date(dataUltimaRevisao);
  d.setMonth(d.getMonth() + Number(cicloMeses));
  return d.toISOString();
}

function diasDesde(dataStr) {
  if (!dataStr) return null;
  return -diasAte(dataStr);
}

function estagioFromPontuacao(p) {
  if (p <= 20) return "Embrionário";
  if (p <= 40) return "Inicial";
  if (p <= 60) return "Básico";
  if (p <= 80) return "Sólido";
  return "Avançado";
}

function toneFromEstagio(estagio) {
  if (estagio === "Embrionário" || estagio === "Inicial") return "red";
  if (estagio === "Básico") return "amber";
  return "green";
}

const HEX_TONE = { green: "#10b981", amber: "#d97706", red: "#dc2626", neutral: "#a8a29e", graphite: "#1c1917" };

function classNames(...itens) {
  return itens.filter(Boolean).join(" ");
}

function formatarValorAuditoria(campo, valor) {
  if (valor === null || valor === undefined || valor === "") return "(vazio)";
  if (typeof valor === "boolean") return valor ? "sim" : "não";
  if (Array.isArray(valor)) return valor.length ? valor.join(", ") : "(vazio)";
  if (campo === "dataProximaRevisao" || campo === "dataConclusao") return formatarData(valor);
  return String(valor);
}

function riscoTone(risco) {
  if (risco === "Alto") return "red";
  if (risco === "Médio") return "amber";
  if (risco === "Baixo") return "green";
  return "neutral";
}

function gravidadeTone(gravidade) {
  if (gravidade === "Crítica" || gravidade === "Alta") return "red";
  if (gravidade === "Média") return "amber";
  return "green";
}

