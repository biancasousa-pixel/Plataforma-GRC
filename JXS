                  </>
                )}
              </dl>
              <p className="mt-3 text-xs leading-relaxed text-stone-500">{t.conteudo}</p>

              <div className="mt-4 grid grid-cols-3 gap-2 text-center">
                <div className="rounded-lg bg-stone-50 px-2 py-2">
                  <p className="text-lg font-semibold tabular-nums text-stone-900">{concluidos}</p>
                  <p className="text-[10px] text-stone-500">concluíram</p>
                </div>
                <div className="rounded-lg bg-stone-50 px-2 py-2">
                  <p className="text-lg font-semibold tabular-nums text-stone-900">{pendentesHeadcount === null ? "—" : pendentesHeadcount}</p>
                  <p className="text-[10px] text-stone-500">ainda não realizaram</p>
                </div>
                <div className="rounded-lg bg-stone-50 px-2 py-2">
                  <p className="text-lg font-semibold tabular-nums text-stone-900">{recemAdmitidos === null ? "—" : recemAdmitidos}</p>
                  <p className="text-[10px] text-stone-500">admitidos há ≤30d, pendentes</p>
                </div>
              </div>

              <div className="mt-3">
                <div className="mb-1 flex items-center justify-between text-xs">
                  <span className="text-stone-500">{designados} designação(ões) registrada(s)</span>
                  <span className="font-medium text-stone-700">{pctHeadcount === null ? "—" : `${pctHeadcount}% do headcount`}</span>
                </div>
                <div className="h-1.5 w-full overflow-hidden rounded-full bg-stone-100">
                  <div className="h-full bg-emerald-500" style={{ width: `${pctHeadcount ?? 0}%` }} />
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <p className="mt-4 text-xs text-stone-400">
        Designações e conclusões são lançadas a partir do perfil de cada colaborador —{" "}
        <button onClick={() => setView("colaboradores")} className="font-medium text-stone-600 underline decoration-stone-300 underline-offset-2 hover:text-stone-900">
          abrir Colaboradores →
        </button>
