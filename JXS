              <Tooltip contentStyle={{ fontSize: 12, borderRadius: 8, border: "1px solid #e7e5e4" }} />
              <Line type="monotone" dataKey="Consolidado" stroke={HEX_TONE.graphite} strokeWidth={2.5} dot={{ r: 4 }} />
              {verPorDimensao && (
                <>
                  <Line type="monotone" dataKey="Sócios" stroke={HEX_TONE[toneFromEstagio(estagioFromPontuacao(ultimaRodada.socios))]} strokeWidth={1.5} dot={{ r: 3 }} />
                  <Line type="monotone" dataKey="Conselho" stroke={HEX_TONE[toneFromEstagio(estagioFromPontuacao(ultimaRodada.conselho))]} strokeWidth={1.5} dot={{ r: 3 }} />
                  <Line type="monotone" dataKey="Diretoria" stroke={HEX_TONE[toneFromEstagio(estagioFromPontuacao(ultimaRodada.diretoria))]} strokeWidth={1.5} dot={{ r: 3 }} strokeDasharray="4 2" />
                  <Line type="monotone" dataKey="Fiscalização" stroke={HEX_TONE[toneFromEstagio(estagioFromPontuacao(ultimaRodada.fiscalizacao))]} strokeWidth={1.5} dot={{ r: 3 }} strokeDasharray="2 2" />
                  <Line type="monotone" dataKey="Conduta" stroke={HEX_TONE[toneFromEstagio(estagioFromPontuacao(ultimaRodada.conduta))]} strokeWidth={1.5} dot={{ r: 3 }} strokeDasharray="6 2" />
