/* ------------------------------ átomos de UI ------------------------------ */

function Dot({ tone = "neutral" }) {
  const map = { green: "bg-emerald-500", amber: "bg-amber-500", red: "bg-red-500", neutral: "bg-stone-300" };
  return <span className={classNames("inline-block h-2 w-2 shrink-0 rounded-full", map[tone])} />;
}

function Tag({ children, tone = "neutral" }) {
  const map = {
    neutral: "bg-stone-100 text-stone-600",
    graphite: "bg-stone-800 text-white",
    green: "bg-emerald-50 text-emerald-700",
    amber: "bg-amber-50 text-amber-700",
    red: "bg-red-50 text-red-700",
  };
  return (
    <span className={classNames("inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium", map[tone])}>
      {children}
    </span>
  );
}

function Avatares({ nomes }) {
  if (!nomes || nomes.length === 0) {
    return <span className="text-xs text-stone-400">Sem responsável</span>;
  }
  return (
    <div className="flex -space-x-2">
      {nomes.slice(0, 3).map((nome, i) => (
        <span
          key={i}
          title={nome}
          className="flex h-6 w-6 items-center justify-center rounded-full border-2 border-white bg-stone-800 text-[10px] font-semibold text-white"
        >
          {nome
            .split(" ")
            .map((p) => p[0])
            .slice(0, 2)
            .join("")
            .toUpperCase()}
        </span>
      ))}
      {nomes.length > 3 && (
        <span className="flex h-6 w-6 items-center justify-center rounded-full border-2 border-white bg-stone-200 text-[10px] font-semibold text-stone-600">
          +{nomes.length - 3}
        </span>
      )}
    </div>
  );
}

function KpiCard({ label, valor, sublabel, tone, tendencia }) {
  return (
    <div className="rounded-xl border border-stone-200 bg-white p-4">
      <p className="text-xs font-medium uppercase tracking-wide text-stone-400">{label}</p>
      <div className="mt-2 flex items-end gap-2">
        <span className="text-2xl font-semibold tabular-nums text-stone-900">{valor}</span>
        <Dot tone={tone} />
        {tendencia !== undefined && tendencia !== null && (
          <span
            className={classNames(
              "mb-0.5 flex items-center text-xs font-medium",
              tendencia > 0 ? "text-emerald-600" : tendencia < 0 ? "text-red-600" : "text-stone-400"
            )}
          >
            {tendencia > 0 ? <ArrowUpRight className="h-3.5 w-3.5" /> : tendencia < 0 ? <ArrowDownRight className="h-3.5 w-3.5" /> : null}
            {tendencia !== 0 ? Math.abs(tendencia) : ""}
          </span>
        )}
