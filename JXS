                  <div key={t.id} className="flex items-center justify-between rounded-lg border border-stone-200 px-3 py-2.5">
                    <div>
                      <p className="text-xs font-medium text-stone-700">{t.nome}</p>
                      <p className="text-[11px] text-stone-400">{designacao ? designacao.status : "Não designado"}</p>
                    </div>
