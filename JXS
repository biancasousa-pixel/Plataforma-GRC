            <div className="space-y-3">
              <div className="flex gap-2">
                <input
                  className={inputCls}
                  placeholder="Escreva um comentário..."
                  value={novoComentario}
                  onChange={(e) => setNovoComentario(e.target.value)}
                  onKeyDown={(e) => {
                    if (e.key === "Enter" && novoComentario.trim()) {
                      onComentar(doc.id, novoComentario.trim());
                      setNovoComentario("");
                    }
                  }}
                />
                <button
                  onClick={() => {
                    if (!novoComentario.trim()) return;
                    onComentar(doc.id, novoComentario.trim());
                    setNovoComentario("");
                  }}
                  className="shrink-0 rounded-lg bg-stone-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-stone-800"
                >
                  Enviar
                </button>
              </div>
              {doc.comentarios.length === 0 && <p className="text-xs text-stone-400">Nenhum comentário ainda.</p>}
              <ul className="space-y-2.5">
                {[...doc.comentarios].reverse().map((c) => (
                  <li key={c.id} className="rounded-lg bg-stone-50 px-3 py-2">
                    <p className="text-xs text-stone-700">{c.texto}</p>
                    <p className="mt-1 text-[11px] text-stone-400">
                      {c.autor} · {tempoRelativo(c.data)}
                    </p>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

