              <div className="grid grid-cols-2 gap-3 pt-2">
                <div className="rounded-lg bg-stone-50 p-3 text-center">
                  <p className="text-lg font-semibold text-stone-900">{designacoesDoColab.filter((d) => d.status === "Concluído").length}</p>
                  <p className="text-[10px] text-stone-500">treinamentos concluídos</p>
                </div>
                <div className="rounded-lg bg-stone-50 p-3 text-center">
                  <p className="text-lg font-semibold text-stone-900">{advsDoColab.length}</p>
                  <p className="text-[10px] text-stone-500">advertências</p>
                </div>
              </div>
            </div>
