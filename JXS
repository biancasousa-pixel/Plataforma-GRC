  return (
    <tr onClick={onClick} className="cursor-pointer border-b border-stone-100 hover:bg-stone-50">
      <td className="px-3 py-2.5">
        <p className="text-xs font-medium text-stone-800">{doc.nome}</p>
      </td>
      <td className="px-3 py-2.5">
        <Tag tone="neutral">{doc.tipo}</Tag>
      </td>
      <td className="px-3 py-2.5 text-xs text-stone-600">{doc.area}</td>
      <td className="px-3 py-2.5">
        <Tag tone={doc.status === "Aprovado" ? "green" : doc.status === "Em revisão" ? "amber" : "neutral"}>{doc.status}</Tag>
      </td>
      <td className="px-3 py-2.5 text-xs text-stone-600">{doc.prioridade}</td>
      <td className="px-3 py-2.5">
        <span className="flex items-center gap-1.5 text-xs text-stone-600">
          <Dot tone={riscoTone(doc.risco)} /> {doc.risco}
        </span>
      </td>
      <td className="px-3 py-2.5 text-xs text-stone-600">
        {formatarData(doc.dataProximaRevisao)}
