      {modalImportarAberto && (
        <ModalImportarColaboradores
          onClose={() => setModalImportarAberto(false)}
          onImportar={(lista) => {
            onImportarColaboradores(lista);
            setModalImportarAberto(false);
          }}
        />
      )}
    </div>
  );
}

function ModalImportarColaboradores({ onClose, onImportar }) {
  const [texto, setTexto] = useState("");
  const [area, setArea] = useState(AREAS[0]);

  const linhas = texto
    .split("\n")
    .map((l) => l.trim())
    .filter(Boolean);

  const pessoas = linhas.map((linha) => {
    const partes = linha.split(",").map((p) => p.trim());
    const email = partes.find((p) => p.includes("@"));
    const nome = partes.find((p) => !p.includes("@")) || partes[0];
    return { nome, email: email || "" };
  });

  return (
    <Modal titulo="Importar lista de colaboradores" onClose={onClose} largura="max-w-lg">
      <div className="space-y-3">
        <Campo label="Cole uma pessoa por linha — 'Nome' ou 'Nome, e-mail'">
          <textarea
            className={classNames(inputCls, "min-h-[140px] resize-none font-mono text-xs")}
            placeholder={"Maria Silva, maria.silva@osklen.com.br\nJoão Pereira, joao.pereira@osklen.com.br\nAna Costa"}
            value={texto}
            onChange={(e) => setTexto(e.target.value)}
          />
        </Campo>
        <Campo label="Área (aplicada a todos desta lista — ajuste depois individualmente se precisar)">
          <select className={inputCls} value={area} onChange={(e) => setArea(e.target.value)}>
            {AREAS.map((a) => (
              <option key={a} value={a}>
                {a}
              </option>
            ))}
          </select>
        </Campo>
        {pessoas.length > 0 && (
          <p className="text-[11px] text-stone-400">
            {pessoas.length} colaborador(es) reconhecido(s): {pessoas.map((p) => p.nome).join(", ")}
          </p>
        )}
        <div className="flex justify-end gap-2 pt-2">
          <button onClick={onClose} className="rounded-lg px-3 py-1.5 text-xs font-medium text-stone-500 hover:bg-stone-100">
            Cancelar
          </button>
          <button
            disabled={pessoas.length === 0}
            onClick={() => onImportar(pessoas.map((p) => ({ ...p, area })))}
            className="rounded-lg bg-stone-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-stone-800 disabled:opacity-40"
          >
            Importar {pessoas.length > 0 ? `(${pessoas.length})` : ""}
          </button>
        </div>
      </div>
    </Modal>
  );
}

