function Dashboard({ documentos, auditLog, ibgcRounds, treinamentos, treinamentoDesignacoes, colaboradores, configuracoes, casos, slaConfig, setView, abrirDocumento, abrirModalRodada }) {
  const [verPorDimensao, setVerPorDimensao] = useState(false);

  const totalDocs = documentos.length;
  const aprovados = documentos.filter((d) => d.status === "Aprovado").length;
  const pctAprovados = totalDocs ? Math.round((aprovados / totalDocs) * 100) : 0;
  const toneAprovados = pctAprovados >= 70 ? "green" : pctAprovados >= 30 ? "amber" : "red";

  const emAtraso = documentos.filter((d) => {
    const dias = diasAte(d.dataProximaRevisao);
    return dias !== null && dias < 0;
  }).length;
  const toneAtraso = emAtraso === 0 ? "green" : emAtraso <= 2 ? "amber" : "red";

  const onboarding = treinamentos.find((t) => t.tipo === "Integração (Onboarding)");
  const designacoesOnboarding = onboarding ? treinamentoDesignacoes.filter((d) => d.treinamentoId === onboarding.id) : [];
  const concluiramOnboarding = designacoesOnboarding.filter((d) => d.status === "Concluído").length;
  const totalHeadcount = configuracoes.totalColaboradoresAtivos || 0;
  const pctIntegracao = totalHeadcount ? Math.round((concluiramOnboarding / totalHeadcount) * 100) : null;

  const ultimaRodada = ibgcRounds[ibgcRounds.length - 1];
  const rodadaAnterior = ibgcRounds.length > 1 ? ibgcRounds[ibgcRounds.length - 2] : null;
  const tendenciaIbgc = rodadaAnterior ? ultimaRodada.consolidado - rodadaAnterior.consolidado : null;
  const toneIbgc = toneFromEstagio(ultimaRodada.estagio);

  const dadosGrafico = ibgcRounds.map((r) => ({
    label: formatarData(r.data),
    Consolidado: r.consolidado,
    Sócios: r.socios,
    Conselho: r.conselho,
    Diretoria: r.diretoria,
    Fiscalização: r.fiscalizacao,
    Conduta: r.conduta,
  }));

  const proximasAcoes = documentos
    .filter((d) => d.dataProximaRevisao)
    .sort((a, b) => new Date(a.dataProximaRevisao) - new Date(b.dataProximaRevisao))
    .slice(0, 5);

  const atividadeRecente = [...auditLog].sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp)).slice(0, 6);

  const contagemStatus = STATUS_COLUNAS.reduce((acc, s) => {
    acc[s] = documentos.filter((d) => d.status === s).length;
    return acc;
  }, {});
  const coresStatus = {
    "Não iniciado": "bg-stone-300",
    "Em andamento": "bg-amber-400",
    "Em revisão": "bg-amber-600",
    Aprovado: "bg-emerald-500",
  };

  const casosAbertos = casos.filter((c) => !["Concluída", "Arquivada"].includes(c.status));
  const casosDentroPrazo = casosAbertos.filter((c) => {
    const dias = diasAte(calcularPrazoCaso(c, slaConfig));
    return dias === null || dias >= 0;
  });
  const pctSla = casosAbertos.length ? Math.round((casosDentroPrazo.length / casosAbertos.length) * 100) : null;

  return (
    <div className="mx-auto max-w-6xl space-y-6">
      <div className="flex flex-wrap items-end justify-between gap-3">
        <div>
          <h1 className="text-lg font-semibold text-stone-900">Programa de Integridade 2.0 — Fase 1 de 4</h1>
          <p className="text-sm text-stone-500">Visão consolidada do programa, atualizada em tempo real pelo comitê.</p>
        </div>
        <button
          onClick={abrirModalRodada}
          className="inline-flex items-center gap-1.5 rounded-lg border border-stone-300 bg-white px-3 py-1.5 text-xs font-medium text-stone-700 hover:bg-stone-50"
        >
          <Plus className="h-3.5 w-3.5" /> Registrar nova rodada IBGC
        </button>
      </div>

      <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <KpiCard
          label="Pontuação IBGC"
          valor={`${ultimaRodada.consolidado}/100`}
          sublabel={`Estágio: ${ultimaRodada.estagio}`}
          tone={toneIbgc}
          tendencia={tendenciaIbgc}
        />
        <KpiCard
          label="Documentos vigentes"
          valor={`${aprovados}/${totalDocs}`}
          sublabel={`${pctAprovados}% da matriz aprovada`}
          tone={toneAprovados}
        />
        <KpiCard
          label="Integração concluída"
          valor={pctIntegracao === null ? "—" : `${pctIntegracao}%`}
          sublabel={totalHeadcount ? `${concluiramOnboarding}/${totalHeadcount} colaboradores` : "Defina o headcount na Administração"}
          tone={pctIntegracao === null ? "neutral" : pctIntegracao >= 70 ? "green" : pctIntegracao >= 30 ? "amber" : "red"}
        />
        <KpiCard label="Tarefas em atraso" valor={emAtraso} sublabel="Documentos com revisão vencida" tone={toneAtraso} />
      </div>

      <div className="rounded-xl border border-stone-200 bg-white p-5">
        <div className="mb-4 flex items-center justify-between">
          <h2 className="text-sm font-semibold text-stone-800">Evolução da Maturidade de Governança</h2>
          <button
            onClick={() => setVerPorDimensao((v) => !v)}
            className="text-xs font-medium text-stone-500 underline decoration-stone-300 underline-offset-2 hover:text-stone-800"
          >
            {verPorDimensao ? "Ver consolidado" : "Ver por dimensão"}
          </button>
        </div>
        <div className="h-64 w-full">
          <ResponsiveContainer width="100%" height="100%">
            <LineChart data={dadosGrafico} margin={{ top: 5, right: 16, left: -16, bottom: 0 }}>
              <CartesianGrid strokeDasharray="3 3" stroke="#f0eee9" vertical={false} />
              <XAxis dataKey="label" tick={{ fontSize: 11, fill: "#a8a29e" }} axisLine={{ stroke: "#e7e5e4" }} tickLine={false} />
              <YAxis domain={[0, 100]} tick={{ fontSize: 11, fill: "#a8a29e" }} axisLine={false} tickLine={false} width={28} />
              <ReferenceLine y={20} stroke="#e7e5e4" strokeDasharray="3 3" />
              <ReferenceLine y={40} stroke="#e7e5e4" strokeDasharray="3 3" />
              <ReferenceLine y={60} stroke="#e7e5e4" strokeDasharray="3 3" />
