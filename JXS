                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}

      {modalAberto && (
        <ModalNovoColaborador
          onClose={() => setModalAberto(false)}
          onSalvar={(dados) => {
            onCriarColaborador(dados);
            setModalAberto(false);
          }}
        />
