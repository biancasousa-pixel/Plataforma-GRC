          const designados = designacoes.length;
          const pendentesHeadcount = total ? Math.max(total - concluidos, 0) : null;
          const pctHeadcount = total ? Math.round((concluidos / total) * 100) : null;

          const recemAdmitidos =
            t.tipo === "Integração (Onboarding)"
              ? colaboradores.filter((c) => {
                  const dias = diasDesde(c.dataAdmissao);
                  if (dias === null || dias > 30) return false;
                  const designacao = designacoes.find((d) => d.colaboradorId === c.id);
                  return !designacao || designacao.status !== "Concluído";
                }).length
              : null;

          return (
            <div key={t.id} className="rounded-xl border border-stone-200 bg-white p-5">
              <div className="flex items-start justify-between">
                <h2 className="text-sm font-semibold text-stone-800">{t.nome}</h2>
                <Tag tone="neutral">{t.formato}</Tag>
              </div>
              <dl className="mt-3 grid grid-cols-2 gap-x-3 gap-y-1.5 text-xs">
