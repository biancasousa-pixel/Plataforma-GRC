function CartaoDocumento({ doc, onClick }) {
  const dias = diasAte(doc.dataProximaRevisao);
  return (
    <div
      draggable
      onDragStart={(e) => e.dataTransfer.setData("text/plain", doc.id)}
      onClick={onClick}
      className="cursor-pointer rounded-lg border border-stone-200 bg-white p-3 shadow-sm hover:border-stone-300 hover:shadow"
    >
      <div className="mb-1.5 flex items-center justify-between">
        <Tag tone="neutral">{doc.tipo}</Tag>
        <Dot tone={riscoTone(doc.risco)} />
      </div>
      <p className="text-xs font-medium leading-snug text-stone-800">{doc.nome}</p>
      <div className="mt-2 flex items-center justify-between">
        <Tag tone="neutral">{doc.area}</Tag>
        <Avatares nomes={doc.responsaveis} />
      </div>
      {dias !== null && dias < 30 && (
        <p className={classNames("mt-2 flex items-center gap-1 text-[11px] font-medium", dias < 0 ? "text-red-600" : "text-amber-600")}>
          <AlertTriangle className="h-3 w-3" /> {dias < 0 ? `revisão atrasada ${Math.abs(dias)}d` : `revisão em ${dias}d`}
        </p>
      )}
    </div>
  );
}

function ColunaKanban({ status, documentos, onClickDoc, onDrop }) {
  return (
    <div
      onDragOver={(e) => e.preventDefault()}
      onDrop={(e) => {
        const id = e.dataTransfer.getData("text/plain");
        onDrop(id, status);
      }}
      className="flex min-h-[200px] flex-1 flex-col rounded-xl bg-stone-100/60 p-2"
    >
      <div className="mb-2 flex items-center justify-between px-1">
        <h3 className="text-xs font-semibold uppercase tracking-wide text-stone-500">{status}</h3>
        <span className="text-xs text-stone-400">{documentos.length}</span>
      </div>
      <div className="space-y-2">
        {documentos.map((doc) => (
          <CartaoDocumento key={doc.id} doc={doc} onClick={() => onClickDoc(doc.id)} />
        ))}
      </div>
    </div>
  );
}

