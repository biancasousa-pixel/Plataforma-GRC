function Biblioteca({ documentos, busca, onClickDoc }) {
  const [pilarFiltro, setPilarFiltro] = useState("");

  const filtrados = documentos.filter((d) => {
    if (busca && !d.nome.toLowerCase().includes(busca.toLowerCase())) return false;
    if (pilarFiltro && d.pilar !== pilarFiltro) return false;
    return true;
  });

  const porPilar = PILARES.map((p) => ({ pilar: p, docs: filtrados.filter((d) => d.pilar === p.nome) }));

  return (
    <div className="mx-auto max-w-6xl">
      <div className="mb-4 flex flex-wrap items-end justify-between gap-3">
        <div>
          <h1 className="text-lg font-semibold text-stone-900">Biblioteca Corporativa</h1>
          <p className="text-xs text-stone-500">
            Os mesmos documentos da Matriz de Controle, organizados para consulta — com validade calculada
            automaticamente.
          </p>
        </div>
        <select value={pilarFiltro} onChange={(e) => setPilarFiltro(e.target.value)} className="rounded-lg border border-stone-300 bg-white px-2.5 py-1.5 text-xs text-stone-600">
          <option value="">Todos os pilares</option>
          {PILARES.map((p) => (
            <option key={p.nome} value={p.nome}>
              {p.nome}
            </option>
          ))}
        </select>
      </div>

      {porPilar.map(
        ({ pilar, docs }) =>
          docs.length > 0 && (
            <div key={pilar.nome} className="mb-6">
              <h2 className="mb-2 text-xs font-semibold uppercase tracking-wide text-stone-400">
                Pilar {String(pilar.numero).padStart(2, "0")} · {pilar.nome}
              </h2>
              <div className="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {docs.map((d) => {
                  const dias = diasAte(d.dataProximaRevisao);
                  const vencido = dias !== null && dias < 0;
                  const venceLogo = dias !== null && dias >= 0 && dias <= 60;
                  return (
                    <button
                      key={d.id}
                      onClick={() => onClickDoc(d.id)}
                      className="rounded-xl border border-stone-200 bg-white p-4 text-left hover:border-stone-300 hover:shadow-sm"
                    >
                      <div className="mb-1.5 flex items-center justify-between">
                        <Tag tone="neutral">{d.tipo}</Tag>
                        <Tag tone={d.status === "Aprovado" ? "green" : "neutral"}>{d.status}</Tag>
                      </div>
                      <p className="text-xs font-medium leading-snug text-stone-800">{d.nome}</p>
                      <p className="mt-1 text-[11px] text-stone-400">{d.area} {d.versao && `· ${d.versao}`}</p>
                      <div className="mt-2.5 border-t border-stone-100 pt-2 text-[11px]">
                        {d.dataProximaRevisao ? (
                          <span className={classNames("flex items-center gap-1 font-medium", vencido ? "text-red-600" : venceLogo ? "text-amber-600" : "text-stone-400")}>
                            {(vencido || venceLogo) && <AlertTriangle className="h-3 w-3" />}
                            {vencido ? `validade vencida há ${Math.abs(dias)}d` : `válido até ${formatarData(d.dataProximaRevisao)}`}
                          </span>
                        ) : (
                          <span className="text-stone-400">Validade não calculada — defina a última revisão</span>
                        )}
                      </div>
                    </button>
                  );
                })}
              </div>
            </div>
          )
      )}

      {filtrados.length === 0 && <p className="text-center text-xs text-stone-400">Nenhum documento encontrado.</p>}
    </div>
  );
}

function Treinamentos({ treinamentos, treinamentoDesignacoes, colaboradores, configuracoes, setView }) {
