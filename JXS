function Colaboradores({ colaboradores, treinamentoDesignacoes, advertencias, treinamentos, configuracoes, busca, onClickColaborador, onCriarColaborador, onImportarColaboradores }) {
  const [modalAberto, setModalAberto] = useState(false);
  const [modalImportarAberto, setModalImportarAberto] = useState(false);

  const filtrados = colaboradores.filter((c) => !busca || c.nome.toLowerCase().includes(busca.toLowerCase()));

  const onboarding = treinamentos.find((t) => t.tipo === "Integração (Onboarding)");
  const designacoesOnboarding = onboarding ? treinamentoDesignacoes.filter((d) => d.treinamentoId === onboarding.id) : [];
  const concluiramOnboarding = designacoesOnboarding.filter((d) => d.status === "Concluído").length;
  const recemAdmitidos = colaboradores.filter((c) => {
    const dias = diasDesde(c.dataAdmissao);
    return dias !== null && dias <= 30;
  }).length;
  const ativos = colaboradores.filter((c) => c.status === "Ativo").length;
  const totalConfigurado = configuracoes.totalColaboradoresAtivos || 0;
  const aindaNaoRealizaram = totalConfigurado ? Math.max(totalConfigurado - concluiramOnboarding, 0) : null;

  return (
    <div className="mx-auto max-w-6xl">
      <div className="mb-4 flex flex-wrap items-center justify-between gap-3">
        <div>
          <h1 className="text-lg font-semibold text-stone-900">Colaboradores</h1>
          <p className="text-xs text-stone-500">{colaboradores.length} cadastrado(s) — histórico individual de treinamento, advertência e documentos.</p>
        </div>
        <div className="flex gap-2">
          <button
            onClick={() => setModalImportarAberto(true)}
            className="inline-flex items-center gap-1.5 rounded-lg border border-stone-300 bg-white px-3 py-1.5 text-xs font-medium text-stone-700 hover:bg-stone-50"
          >
            <Users className="h-3.5 w-3.5" /> Importar lista
          </button>
          <button
            onClick={() => setModalAberto(true)}
            className="inline-flex items-center gap-1.5 rounded-lg bg-stone-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-stone-800"
          >
            <Plus className="h-3.5 w-3.5" /> Novo colaborador
          </button>
        </div>
      </div>

      <div className="mb-5 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <KpiCard label="Colaboradores ativos" valor={ativos} sublabel={totalConfigurado ? `${totalConfigurado} configurado(s) na Administração` : "Configure o headcount na Administração"} tone="neutral" />
        <KpiCard label="Concluíram a integração" valor={concluiramOnboarding} sublabel="Onboarding — Concluído" tone="green" />
        <KpiCard label="Ainda não realizaram" valor={aindaNaoRealizaram === null ? "—" : aindaNaoRealizaram} sublabel={totalConfigurado ? "Baseado no headcount" : "Defina o headcount"} tone={aindaNaoRealizaram === null ? "neutral" : aindaNaoRealizaram === 0 ? "green" : "amber"} />
        <KpiCard label="Entraram recentemente" valor={recemAdmitidos} sublabel="Admitidos nos últimos 30 dias" tone="neutral" />
      </div>

      {colaboradores.length === 0 ? (
        <div className="rounded-xl border border-stone-200 bg-white p-8 text-center">
          <Users className="mx-auto h-6 w-6 text-stone-300" />
          <p className="mt-2 text-xs text-stone-400">
            Nenhum colaborador cadastrado ainda. Cadastre um a um ou cole uma lista de uma vez — o histórico de
            treinamento e advertência fica atrelado ao perfil de cada pessoa.
          </p>
        </div>
      ) : (
        <div className="overflow-x-auto rounded-xl border border-stone-200 bg-white">
          <table className="w-full">
            <thead>
              <tr className="border-b border-stone-200 bg-stone-50 text-left text-[11px] font-semibold uppercase tracking-wide text-stone-500">
                <th className="px-3 py-2">Nome</th>
                <th className="px-3 py-2">Cargo</th>
                <th className="px-3 py-2">Área</th>
                <th className="px-3 py-2">Admissão</th>
                <th className="px-3 py-2">Status</th>
                <th className="px-3 py-2">Treinamentos</th>
                <th className="px-3 py-2">Advertências</th>
              </tr>
            </thead>
            <tbody>
              {filtrados.map((c) => {
                const concluidos = treinamentoDesignacoes.filter((d) => d.colaboradorId === c.id && d.status === "Concluído").length;
                const advsCount = advertencias.filter((a) => a.colaboradorId === c.id).length;
                return (
                  <tr key={c.id} onClick={() => onClickColaborador(c.id)} className="cursor-pointer border-b border-stone-100 hover:bg-stone-50">
                    <td className="px-3 py-2.5 text-xs font-medium text-stone-800">{c.nome}</td>
                    <td className="px-3 py-2.5 text-xs text-stone-600">{c.cargo || "—"}</td>
                    <td className="px-3 py-2.5 text-xs text-stone-600">{c.area || "—"}</td>
                    <td className="px-3 py-2.5 text-xs text-stone-600">{formatarData(c.dataAdmissao)}</td>
                    <td className="px-3 py-2.5">
                      <Tag tone={c.status === "Ativo" ? "green" : "neutral"}>{c.status}</Tag>
                    </td>
                    <td className="px-3 py-2.5 text-xs text-stone-600">{concluidos} concluído(s)</td>
                    <td className="px-3 py-2.5">
                      {advsCount > 0 ? <Tag tone="amber">{advsCount}</Tag> : <span className="text-xs text-stone-400">—</span>}
