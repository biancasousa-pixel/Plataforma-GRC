function ListaContagem({ titulo, dados }) {
  const max = Math.max(1, ...dados.map((d) => d.total));
  const algum = dados.some((d) => d.total > 0);
  return (
    <div className="rounded-xl border border-stone-200 bg-white p-5">
      <h2 className="mb-3 text-sm font-semibold text-stone-800">{titulo}</h2>
      {!algum && <p className="text-xs text-stone-400">Nenhum dado ainda.</p>}
      {algum && (
        <div className="space-y-2">
          {dados.map((d) => (
            <div key={d.rotulo}>
              <div className="mb-0.5 flex items-center justify-between text-xs">
                <span className="text-stone-600">{d.rotulo}</span>
                <span className="font-medium text-stone-800">{d.total}</span>
              </div>
              <div className="h-1.5 w-full overflow-hidden rounded-full bg-stone-100">
                <div className="h-full bg-stone-700" style={{ width: `${(d.total / max) * 100}%` }} />
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

function painelContagem(itens, campo, opcoes) {
  const contagem = {};
  opcoes.forEach((o) => (contagem[o] = 0));
  itens.forEach((it) => {
    if (contagem[it[campo]] !== undefined) contagem[it[campo]] += 1;
  });
  return opcoes.map((o) => ({ rotulo: o, total: contagem[o] || 0 }));
}

