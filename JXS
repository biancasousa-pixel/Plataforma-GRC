/* ------------------------------- modal rodada IBGC ------------------------------- */

function ModalNovaRodada({ onClose, onSalvar }) {
  const [form, setForm] = useState({ data: new Date().toISOString().slice(0, 10), socios: 50, conselho: 50, diretoria: 50, fiscalizacao: 50, conduta: 50 });
  const consolidado = Math.round((Number(form.socios) + Number(form.conselho) + Number(form.diretoria) + Number(form.fiscalizacao) + Number(form.conduta)) / 5);

  const campos = [
    { chave: "socios", rotulo: "Sócios" },
    { chave: "conselho", rotulo: "Conselho de Administração" },
    { chave: "diretoria", rotulo: "Diretoria" },
    { chave: "fiscalizacao", rotulo: "Órgãos de Fiscalização e Controle" },
    { chave: "conduta", rotulo: "Conduta e Conflitos de Interesse" },
  ];

  return (
    <Modal titulo="Registrar nova rodada da Métrica IBGC" onClose={onClose}>
      <div className="space-y-3">
        <Campo label="Data da avaliação">
          <input type="date" className={inputCls} value={form.data} onChange={(e) => setForm({ ...form, data: e.target.value })} />
        </Campo>
        {campos.map((c) => (
          <Campo key={c.chave} label={`${c.rotulo} (0–100)`}>
            <input
              type="number"
              min={0}
              max={100}
              className={inputCls}
              value={form[c.chave]}
              onChange={(e) => setForm({ ...form, [c.chave]: e.target.value })}
            />
          </Campo>
        ))}
        <div className="rounded-lg bg-stone-50 px-3 py-2 text-xs text-stone-600">
          Pontuação consolidada (média simples): <span className="font-semibold text-stone-900">{consolidado}/100</span> ·{" "}
          {estagioFromPontuacao(consolidado)}
        </div>
        <div className="flex justify-end gap-2 pt-2">
          <button onClick={onClose} className="rounded-lg px-3 py-1.5 text-xs font-medium text-stone-500 hover:bg-stone-100">
            Cancelar
          </button>
          <button
            onClick={() =>
              onSalvar({
                data: form.data,
                socios: Number(form.socios),
                conselho: Number(form.conselho),
                diretoria: Number(form.diretoria),
                fiscalizacao: Number(form.fiscalizacao),
                conduta: Number(form.conduta),
                consolidado,
                estagio: estagioFromPontuacao(consolidado),
              })
            }
            className="rounded-lg bg-stone-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-stone-800"
          >
            Salvar rodada
          </button>
        </div>
      </div>
    </Modal>
  );
}

