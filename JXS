                  <ShieldAlert className="h-3.5 w-3.5" /> Nova advertência
                </p>
                <div className="space-y-2">
                  <select className={classNames(inputCls, "text-xs")} value={novaAdv.tipo} onChange={(e) => setNovaAdv({ ...novaAdv, tipo: e.target.value })}>
