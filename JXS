  const [colaboradorSelecionadoId, setColaboradorSelecionadoId] = useState(null);
  const [modalRodadaAberto, setModalRodadaAberto] = useState(false);
  const [bannerVisivel, setBannerVisivel] = useState(true);

  const carregarRef = useRef(false);

  useEffect(() => {
    (async () => {
      const [docs, log, rodadas, trein, treinDesig, flags, casosCarregados, sla, colabs, advs, config, perfilSalvo, bannerSalvo] = await Promise.all([
        storageGet(STORAGE.documentos, true),
        storageGet(STORAGE.auditLog, true),
        storageGet(STORAGE.ibgcRounds, true),
        storageGet(STORAGE.treinamentos, true),
        storageGet(STORAGE.treinamentoDesignacoes, true),
        storageGet(STORAGE.featureFlags, true),
        storageGet(STORAGE.casos, true),
        storageGet(STORAGE.slaConfig, true),
        storageGet(STORAGE.colaboradores, true),
        storageGet(STORAGE.advertencias, true),
        storageGet(STORAGE.configuracoes, true),
        storageGet("osklen-grc-perfil-v1", false),
        storageGet("osklen-grc-banner-v1", false),
      ]);

      const docsIniciais = docs && docs.length ? docs : seedDocumentos();
      setDocumentos(docsIniciais);
      setAuditLog(log && log.length ? log : seedAuditLog(docsIniciais));
      setIbgcRounds(rodadas && rodadas.length ? rodadas : seedIbgcRounds());
      setTreinamentos(trein && trein.length ? trein : seedTreinamentos());
      setTreinamentoDesignacoes(treinDesig || seedTreinamentoDesignacoes());
      setFeatureFlags(flags && flags.length ? flags : seedFeatureFlags());
      setCasos(casosCarregados || seedCasos());
      setSlaConfig(sla && sla.length ? sla : seedSlaConfig());
      setColaboradores(colabs || seedColaboradores());
      setAdvertencias(advs || seedAdvertencias());
      setConfiguracoes(config || seedConfiguracoes());
      if (perfilSalvo) setPerfil(perfilSalvo);
      if (bannerSalvo && bannerSalvo.dispensado) setBannerVisivel(false);

      carregarRef.current = true;
      setCarregado(true);
    })();
  }, []);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.documentos, documentos, true);
  }, [documentos]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.auditLog, auditLog, true);
  }, [auditLog]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.ibgcRounds, ibgcRounds, true);
  }, [ibgcRounds]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.treinamentos, treinamentos, true);
  }, [treinamentos]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.treinamentoDesignacoes, treinamentoDesignacoes, true);
  }, [treinamentoDesignacoes]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.featureFlags, featureFlags, true);
  }, [featureFlags]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.casos, casos, true);
  }, [casos]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.slaConfig, slaConfig, true);
  }, [slaConfig]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.colaboradores, colaboradores, true);
  }, [colaboradores]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.advertencias, advertencias, true);
  }, [advertencias]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet(STORAGE.configuracoes, configuracoes, true);
  }, [configuracoes]);

  useEffect(() => {
    if (!carregarRef.current) return;
    storageSet("osklen-grc-perfil-v1", perfil, false);
  }, [perfil]);

  function aplicarAtualizacaoDocumento(id, patch) {
    setDocumentos((prev) => {
      const atual = prev.find((d) => d.id === id);
      if (!atual) return prev;
      const novasEntradas = [];
      Object.keys(patch).forEach((campo) => {
        const valorAntigo = atual[campo];
        const valorNovo = patch[campo];
        if (JSON.stringify(valorAntigo) === JSON.stringify(valorNovo)) return;
        novasEntradas.push({
          id: uid("log"),
          documentoId: id,
          documentoNome: atual.nome,
          campo,
          valorAntigo,
          valorNovo,
          usuario: perfil.nome,
          papel: perfil.papel,
          timestamp: new Date().toISOString(),
        });
      });
      if (novasEntradas.length) {
        setAuditLog((prevLog) => [...novasEntradas, ...prevLog].slice(0, 200));
      }
      return prev.map((d) => (d.id === id ? { ...d, ...patch, atualizadoEm: new Date().toISOString() } : d));
    });
  }

  function criarDocumento(dados) {
    const novo = {
      id: uid("doc"),
      nome: dados.nome,
      tipo: dados.tipo,
      classificacao: dados.classificacao,
      area: dados.area,
      pilar: dados.pilar,
      status: "Não iniciado",
      prioridade: dados.prioridade,
      risco: dados.risco,
      versao: null,
      dataProximaRevisao: null,
      responsaveis: [],
      acaoRecomendada: null,
      observacoes: "",
      linkDocumento: null,
      anexos: [],
      comentarios: [],
      criadoEm: new Date().toISOString(),
      atualizadoEm: new Date().toISOString(),
    };
    setDocumentos((prev) => [novo, ...prev]);
    setAuditLog((prev) =>
      [
        {
          id: uid("log"),
          documentoId: novo.id,
          documentoNome: novo.nome,
          campo: "nome",
          valorAntigo: null,
          valorNovo: novo.nome,
          usuario: perfil.nome,
          papel: perfil.papel,
          timestamp: new Date().toISOString(),
        },
        ...prev,
      ].slice(0, 200)
    );
  }

  function adicionarComentario(docId, texto) {
    setDocumentos((prev) =>
      prev.map((d) =>
        d.id === docId
          ? { ...d, comentarios: [...d.comentarios, { id: uid("com"), texto, autor: perfil.nome, data: new Date().toISOString() }] }
          : d
      )
    );
  }

  function adicionarAnexo(docId, nome) {
    setDocumentos((prev) =>
      prev.map((d) =>
        d.id === docId
          ? { ...d, anexos: [...d.anexos, { id: uid("anx"), nome, enviadoPor: perfil.nome, data: new Date().toISOString() }] }
          : d
      )
    );
  }

  function removerAnexo(docId, anexoId) {
    setDocumentos((prev) => prev.map((d) => (d.id === docId ? { ...d, anexos: d.anexos.filter((a) => a.id !== anexoId) } : d)));
  }

  function moverStatus(docId, novoStatus) {
    aplicarAtualizacaoDocumento(docId, { status: novoStatus });
  }

  function toggleFeatureFlag(recurso) {
    setFeatureFlags((prev) => prev.map((f) => (f.recurso === recurso ? { ...f, restricaoAtiva: !f.restricaoAtiva } : f)));
  }

  function registrarRodadaIbgc(dados) {
    setIbgcRounds((prev) => [...prev, { id: uid("rodada"), ...dados }]);
    setModalRodadaAberto(false);
  }

  /* ---------- casos de integridade ---------- */

  function criarCaso(dados) {
    const protocolo = `CI-${new Date().getFullYear()}-${String(casos.length + 1).padStart(4, "0")}`;
    const agora = new Date().toISOString();
    const novo = {
      id: uid("caso"),
      protocolo,
      canalOrigem: dados.canalOrigem,
      categoria: dados.categoria,
      areaRelacionada: dados.areaRelacionada,
      gravidade: dados.gravidade,
      sigilo: dados.sigilo,
      denuncianteAnonimo: dados.denuncianteAnonimo,
      resumoInicial: dados.resumoInicial || "",
      status: "Recebida",
      responsavelInvestigacao: null,
      dataRecebimento: agora,
      dataConclusao: null,
      desfecho: null,
      andamentos: [{ id: uid("and"), tipo: "Registro", descricao: "Caso registrado no canal.", autor: perfil.nome, data: agora }],
      anexos: [],
      documentosRelacionados: [],
      criadoEm: agora,
      atualizadoEm: agora,
    };
    setCasos((prev) => [novo, ...prev]);
  }

  function aplicarAtualizacaoCaso(id, patch) {
    setCasos((prev) =>
      prev.map((c) => {
        if (c.id !== id) return c;
        const novosAndamentos = [];
        Object.keys(patch).forEach((campo) => {
          if (JSON.stringify(c[campo]) === JSON.stringify(patch[campo])) return;
          novosAndamentos.push({
            id: uid("and"),
            tipo: "Atualização",
            descricao: `${FIELD_LABELS_CASO[campo] || campo} alterado de "${formatarValorAuditoria(campo, c[campo])}" para "${formatarValorAuditoria(
              campo,
              patch[campo]
            )}"`,
            autor: perfil.nome,
            data: new Date().toISOString(),
          });
        });
        return {
          ...c,
          ...patch,
          andamentos: [...novosAndamentos, ...c.andamentos],
          atualizadoEm: new Date().toISOString(),
        };
      })
    );
  }

  function moverStatusCaso(id, novoStatus) {
    aplicarAtualizacaoCaso(id, { status: novoStatus });
  }

  function adicionarAndamentoCaso(id, descricao) {
    setCasos((prev) =>
      prev.map((c) =>
        c.id === id
          ? { ...c, andamentos: [{ id: uid("and"), tipo: "Nota", descricao, autor: perfil.nome, data: new Date().toISOString() }, ...c.andamentos] }
          : c
      )
    );
  }

  function anexarCaso(id, nome) {
    setCasos((prev) =>
      prev.map((c) =>
        c.id === id ? { ...c, anexos: [...c.anexos, { id: uid("anx"), nome, enviadoPor: perfil.nome, data: new Date().toISOString() }] } : c
      )
    );
  }

  function removerAnexoCaso(id, anexoId) {
    setCasos((prev) => prev.map((c) => (c.id === id ? { ...c, anexos: c.anexos.filter((a) => a.id !== anexoId) } : c)));
  }

  function vincularDocumentoCaso(casoId, documentoId, trecho) {
    const doc = documentos.find((d) => d.id === documentoId);
    if (!doc) return;
    setCasos((prev) =>
      prev.map((c) =>
        c.id === casoId
          ? { ...c, documentosRelacionados: [...c.documentosRelacionados, { id: uid("vinc"), documentoId, documentoNome: doc.nome, trecho }] }
          : c
      )
    );
  }

  function desvincularDocumentoCaso(casoId, vinculoId) {
    setCasos((prev) =>
      prev.map((c) => (c.id === casoId ? { ...c, documentosRelacionados: c.documentosRelacionados.filter((v) => v.id !== vinculoId) } : c))
    );
  }

  function atualizarSla(categoria, prazoDias) {
    setSlaConfig((prev) => prev.map((s) => (s.categoria === categoria ? { ...s, prazoDias } : s)));
  }

  /* ---------- colaboradores, treinamentos por pessoa, advertências ---------- */

  function criarColaborador(dados) {
    const novo = {
      id: uid("colab"),
      nome: dados.nome,
      email: dados.email || "",
      cargo: dados.cargo || "",
      area: dados.area,
      dataAdmissao: dados.dataAdmissao || new Date().toISOString().slice(0, 10),
      status: "Ativo",
      criadoEm: new Date().toISOString(),
      atualizadoEm: new Date().toISOString(),
    };
    setColaboradores((prev) => [novo, ...prev]);
  }

  function importarColaboradores(lista) {
    const agora = new Date().toISOString();
    const novos = lista.map((p) => ({
      id: uid("colab"),
      nome: p.nome,
      email: p.email || "",
      cargo: "",
      area: p.area,
      dataAdmissao: agora.slice(0, 10),
      status: "Ativo",
      criadoEm: agora,
      atualizadoEm: agora,
    }));
    setColaboradores((prev) => [...novos, ...prev]);
  }

  function atualizarColaborador(id, patch) {
    setColaboradores((prev) => prev.map((c) => (c.id === id ? { ...c, ...patch, atualizadoEm: new Date().toISOString() } : c)));
  }

  function designarTreinamento(colaboradorId, treinamentoId) {
    setTreinamentoDesignacoes((prev) => {
      if (prev.some((d) => d.colaboradorId === colaboradorId && d.treinamentoId === treinamentoId)) return prev;
      return [
        ...prev,
        { id: uid("desig"), colaboradorId, treinamentoId, status: "Pendente", dataDesignacao: new Date().toISOString(), dataConclusao: null },
      ];
    });
  }

  function concluirDesignacao(designacaoId) {
    setTreinamentoDesignacoes((prev) =>
      prev.map((d) => (d.id === designacaoId ? { ...d, status: "Concluído", dataConclusao: new Date().toISOString() } : d))
    );
  }

  function adicionarAdvertencia(colaboradorId, dados) {
    setAdvertencias((prev) => [
      {
        id: uid("adv"),
        colaboradorId,
        tipo: dados.tipo,
        motivo: dados.motivo,
        casoRelacionadoId: dados.casoRelacionadoId || null,
        responsavel: perfil.nome,
        dataRegistro: new Date().toISOString(),
      },
      ...prev,
    ]);
  }

  function atualizarConfiguracoes(patch) {
    setConfiguracoes((prev) => ({ ...prev, ...patch }));
  }

  function restaurarDadosDeExemplo() {
    const docs = seedDocumentos();
    setDocumentos(docs);
    setAuditLog(seedAuditLog(docs));
    setIbgcRounds(seedIbgcRounds());
    setTreinamentos(seedTreinamentos());
    setTreinamentoDesignacoes(seedTreinamentoDesignacoes());
    setFeatureFlags(seedFeatureFlags());
    setCasos(seedCasos());
    setSlaConfig(seedSlaConfig());
    setColaboradores(seedColaboradores());
    setAdvertencias(seedAdvertencias());
    setConfiguracoes(seedConfiguracoes());
  }

  function dispensarBanner() {
    setBannerVisivel(false);
    storageSet("osklen-grc-banner-v1", { dispensado: true }, false);
  }

  const docSelecionado = documentos.find((d) => d.id === docSelecionadoId) || null;
  const auditEntriesDoc = docSelecionadoId
    ? auditLog.filter((e) => e.documentoId === docSelecionadoId).sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp))
    : [];

  const casoSelecionado = casos.find((c) => c.id === casoSelecionadoId) || null;

  const colaboradorSelecionado = colaboradores.find((c) => c.id === colaboradorSelecionadoId) || null;

  const notificacoesDocs = documentos
    .filter((d) => {
      const dias = diasAte(d.dataProximaRevisao);
      return dias !== null && dias <= 30;
    })
    .map((d) => ({ id: d.id, tipo: "documento", nome: d.nome, contexto: d.area, dias: diasAte(d.dataProximaRevisao) }));

  const notificacoesCasos = casos
    .filter((c) => !["Concluída", "Arquivada"].includes(c.status))
    .map((c) => ({ id: c.id, tipo: "caso", nome: c.protocolo, contexto: c.categoria, dias: diasAte(calcularPrazoCaso(c, slaConfig)) }))
    .filter((n) => n.dias !== null && n.dias <= 30);

  const notificacoes = [...notificacoesDocs, ...notificacoesCasos].sort((a, b) => a.dias - b.dias);

  function clicarNotificacao(n) {
    if (n.tipo === "documento") {
      setView("matriz");
      setDocSelecionadoId(n.id);
    } else {
      setView("denuncias");
      setCasoSelecionadoId(n.id);
    }
  }

  if (!carregado) {
    return (
      <div className="flex h-full min-h-[400px] items-center justify-center bg-stone-50 text-sm text-stone-400">
        Carregando plataforma...
      </div>
    );
  }

  return (
    <div
      className="flex h-full min-h-[700px] w-full overflow-hidden bg-stone-50 text-stone-900"
      style={{ fontFamily: "ui-sans-serif, system-ui, -apple-system, sans-serif" }}
    >
      <Sidebar aberta={sidebarAberta} setAberta={setSidebarAberta} view={view} setView={setView} />
      <div className="flex min-w-0 flex-1 flex-col">
        <TopBar
          busca={busca}
          setBusca={setBusca}
          view={view}
          perfil={perfil}
          setPerfil={setPerfil}
          notificacoes={notificacoes}
          onClickNotificacao={clicarNotificacao}
        />
        <main className="flex-1 overflow-y-auto p-6">
          {bannerVisivel && (
            <div className="mx-auto mb-5 flex max-w-6xl items-start justify-between gap-3 rounded-xl border border-stone-200 bg-white px-4 py-3 text-xs text-stone-600">
              <p>
                Protótipo funcional, seeded com os dados reais da Matriz de Controle e do Relatório IBGC da Osklen. Os
                dados ficam salvos e são <strong>compartilhados com todos que abrirem este artifact</strong>.
              </p>
              <button onClick={dispensarBanner} className="shrink-0 text-stone-400 hover:text-stone-700">
                <X className="h-3.5 w-3.5" />
              </button>
            </div>
          )}

          {view === "dashboard" && (
            <Dashboard
              documentos={documentos}
              auditLog={auditLog}
              ibgcRounds={ibgcRounds}
              treinamentos={treinamentos}
              treinamentoDesignacoes={treinamentoDesignacoes}
              colaboradores={colaboradores}
              configuracoes={configuracoes}
              casos={casos}
              slaConfig={slaConfig}
              setView={setView}
              abrirDocumento={setDocSelecionadoId}
              abrirModalRodada={() => setModalRodadaAberto(true)}
            />
          )}
          {view === "fluxos" && <Fluxos documentos={documentos} />}
          {view === "matriz" && (
            <Matriz
              documentos={documentos}
              busca={busca}
              onClickDoc={setDocSelecionadoId}
              onMoveStatus={moverStatus}
              onCriarDocumento={criarDocumento}
            />
          )}
          {view === "biblioteca" && <Biblioteca documentos={documentos} busca={busca} onClickDoc={setDocSelecionadoId} />}
          {view === "colaboradores" && (
            <Colaboradores
              colaboradores={colaboradores}
              treinamentoDesignacoes={treinamentoDesignacoes}
              advertencias={advertencias}
              treinamentos={treinamentos}
              configuracoes={configuracoes}
              busca={busca}
              onClickColaborador={setColaboradorSelecionadoId}
              onCriarColaborador={criarColaborador}
              onImportarColaboradores={importarColaboradores}
            />
          )}
          {view === "treinamentos" && (
            <Treinamentos
              treinamentos={treinamentos}
              treinamentoDesignacoes={treinamentoDesignacoes}
              colaboradores={colaboradores}
              configuracoes={configuracoes}
              setView={setView}
            />
          )}
          {view === "denuncias" && (
            <Casos
              casos={casos}
              slaConfig={slaConfig}
              busca={busca}
              onClickCaso={setCasoSelecionadoId}
              onMoveStatus={moverStatusCaso}
              onCriarCaso={criarCaso}
            />
          )}
          {view === "admin" && (
            <Admin
              featureFlags={featureFlags}
              onToggleFlag={toggleFeatureFlag}
              ibgcRounds={ibgcRounds}
              slaConfig={slaConfig}
              onAtualizarSla={atualizarSla}
              configuracoes={configuracoes}
              onAtualizarConfiguracoes={atualizarConfiguracoes}
              onResetar={restaurarDadosDeExemplo}
            />
          )}
        </main>
      </div>

      {docSelecionado && (
        <DetailDrawer
          doc={docSelecionado}
          auditEntries={auditEntriesDoc}
          onClose={() => setDocSelecionadoId(null)}
          onUpdate={aplicarAtualizacaoDocumento}
          onComentar={adicionarComentario}
          onAnexar={adicionarAnexo}
          onRemoverAnexo={removerAnexo}
        />
      )}

      {casoSelecionado && (
        <CasoDrawer
          caso={casoSelecionado}
          slaConfig={slaConfig}
          documentos={documentos}
          onClose={() => setCasoSelecionadoId(null)}
          onUpdate={aplicarAtualizacaoCaso}
          onAndamento={adicionarAndamentoCaso}
          onAnexar={anexarCaso}
          onRemoverAnexo={removerAnexoCaso}
          onVincularDocumento={vincularDocumentoCaso}
          onDesvincularDocumento={desvincularDocumentoCaso}
        />
      )}

      {colaboradorSelecionado && (
        <ColaboradorDrawer
          colaborador={colaboradorSelecionado}
          treinamentos={treinamentos}
          treinamentoDesignacoes={treinamentoDesignacoes}
          advertencias={advertencias}
          casos={casos}
          onClose={() => setColaboradorSelecionadoId(null)}
          onUpdate={atualizarColaborador}
          onDesignar={designarTreinamento}
          onConcluirDesignacao={concluirDesignacao}
          onAdicionarAdvertencia={adicionarAdvertencia}
        />
      )}

      {modalRodadaAberto && <ModalNovaRodada onClose={() => setModalRodadaAberto(false)} onSalvar={registrarRodadaIbgc} />}
    </div>
  );
}

export default App;
