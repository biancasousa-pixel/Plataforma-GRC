            Abrir canal completo →
          </button>
        </div>

        <div className="rounded-xl border border-stone-200 bg-white p-5">
          <h2 className="mb-3 text-sm font-semibold text-stone-800">Próximas ações</h2>
          {proximasAcoes.length === 0 && <p className="text-xs text-stone-400">Nenhum documento com data de revisão definida ainda.</p>}
