function CasoDrawer({ caso, slaConfig, documentos, onClose, onUpdate, onAndamento, onAnexar, onRemoverAnexo, onVincularDocumento, onDesvincularDocumento }) {
  const [aba, setAba] = useState("geral");
  const [novoAndamento, setNovoAndamento] = useState("");
  const [novoAnexo, setNovoAnexo] = useState("");
  const [vinculoDocId, setVinculoDocId] = useState("");
  const [vinculoTrecho, setVinculoTrecho] = useState("");

  if (!caso) return null;

  const prazo = calcularPrazoCaso(caso, slaConfig);
  const dias = diasAte(prazo);
  const emAberto = !["Concluída", "Arquivada"].includes(caso.status);
  const slaDias = slaConfig.find((s) => s.categoria === caso.categoria)?.prazoDias ?? 30;

  return (
    <div className="fixed inset-0 z-40 flex justify-end bg-stone-900/30">
      <div className="flex h-full w-full max-w-md flex-col bg-white shadow-2xl">
        <div className="flex items-start justify-between border-b border-stone-200 px-5 py-4">
          <div className="min-w-0">
            <Tag tone="neutral">{caso.categoria}</Tag>
            <h3 className="mt-1.5 truncate text-sm font-semibold text-stone-900">{caso.protocolo}</h3>
          </div>
          <button onClick={onClose} className="rounded-full p-1.5 text-stone-400 hover:bg-stone-100 hover:text-stone-700">
            <X className="h-4 w-4" />
          </button>
        </div>

        <div className="flex border-b border-stone-200 px-5">
          {[
            { chave: "geral", rotulo: "Visão Geral" },
            { chave: "linha", rotulo: "Linha do Tempo" },
            { chave: "anexos", rotulo: "Anexos" },
          ].map((t) => (
            <button
              key={t.chave}
              onClick={() => setAba(t.chave)}
              className={classNames(
                "border-b-2 px-3 py-2.5 text-xs font-medium",
                aba === t.chave ? "border-stone-900 text-stone-900" : "border-transparent text-stone-400 hover:text-stone-600"
              )}
            >
              {t.rotulo}
            </button>
          ))}
