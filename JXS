}

function FiltrosMatriz({ filtros, setFiltros, aberta, setAberta }) {
  const camposFiltro = [
    { chave: "area", rotulo: "Área", opcoes: AREAS },
    { chave: "tipo", rotulo: "Tipo", opcoes: TIPOS_DOCUMENTO.map((t) => t.atual) },
    { chave: "prioridade", rotulo: "Prioridade", opcoes: ["Alta", "Média", "Baixa"] },
    { chave: "risco", rotulo: "Risco", opcoes: ["Alto", "Médio", "Baixo"] },
  ];
  const algumFiltroAtivo = Object.values(filtros).some((v) => v !== "");

  return (
    <div className="mb-3">
      <button onClick={() => setAberta(!aberta)} className="flex items-center gap-1.5 text-xs font-medium text-stone-500 hover:text-stone-800">
        <ChevronDown className={classNames("h-3.5 w-3.5 transition-transform", aberta && "rotate-180")} />
        Filtros
        {algumFiltroAtivo && <span className="ml-1 rounded-full bg-stone-800 px-1.5 text-[10px] text-white">ativos</span>}
      </button>
      {aberta && (
        <div className="mt-2 flex flex-wrap gap-2">
          {camposFiltro.map((c) => (
            <select
              key={c.chave}
              value={filtros[c.chave]}
              onChange={(e) => setFiltros({ ...filtros, [c.chave]: e.target.value })}
              className="rounded-lg border border-stone-300 bg-white px-2.5 py-1 text-xs text-stone-600 outline-none focus:border-stone-500"
            >
              <option value="">{c.rotulo}: todos</option>
              {c.opcoes.map((op) => (
                <option key={op} value={op}>
                  {op}
                </option>
              ))}
            </select>
          ))}
          {algumFiltroAtivo && (
            <button
              onClick={() => setFiltros({ area: "", tipo: "", prioridade: "", risco: "" })}
              className="text-xs font-medium text-stone-400 hover:text-stone-700"
            >
              Limpar filtros
            </button>
          )}
        </div>
      )}
    </div>
  );
}

function Matriz({ documentos, busca, onClickDoc, onMoveStatus, onCriarDocumento }) {
  const [modo, setModo] = useState("kanban");
  const [filtros, setFiltros] = useState({ area: "", tipo: "", prioridade: "", risco: "" });
  const [filtrosAbertos, setFiltrosAbertos] = useState(false);
  const [modalNovoAberto, setModalNovoAberto] = useState(false);
  const [sort, setSort] = useState({ campo: "nome", dir: 1 });

  const filtrados = useMemo(() => {
    return documentos.filter((d) => {
      if (busca && !d.nome.toLowerCase().includes(busca.toLowerCase())) return false;
      if (filtros.area && d.area !== filtros.area) return false;
      if (filtros.tipo && d.tipo !== filtros.tipo) return false;
      if (filtros.prioridade && d.prioridade !== filtros.prioridade) return false;
      if (filtros.risco && d.risco !== filtros.risco) return false;
      return true;
    });
  }, [documentos, busca, filtros]);

  const ordenados = useMemo(() => {
    const copia = [...filtrados];
    copia.sort((a, b) => {
      const va = a[sort.campo] ?? "";
      const vb = b[sort.campo] ?? "";
      return va > vb ? sort.dir : va < vb ? -sort.dir : 0;
    });
    return copia;
  }, [filtrados, sort]);

  function alternarOrdenacao(campo) {
    setSort((prev) => (prev.campo === campo ? { campo, dir: -prev.dir } : { campo, dir: 1 }));
  }

  const colunasTabela = [
    { campo: "nome", rotulo: "Nome" },
    { campo: "tipo", rotulo: "Tipo" },
    { campo: "area", rotulo: "Área" },
    { campo: "status", rotulo: "Status" },
    { campo: "prioridade", rotulo: "Prioridade" },
    { campo: "risco", rotulo: "Risco" },
    { campo: "dataProximaRevisao", rotulo: "Próx. revisão" },
    { campo: null, rotulo: "Responsáveis" },
  ];

  return (
    <div className="mx-auto max-w-6xl">
      <div className="mb-4 flex flex-wrap items-center justify-between gap-3">
        <div>
          <h1 className="text-lg font-semibold text-stone-900">Matriz de Controle e Revisão</h1>
          <p className="text-xs text-stone-500">{filtrados.length} de {documentos.length} documentos</p>
        </div>
        <div className="flex items-center gap-2">
          <div className="flex rounded-lg border border-stone-300 p-0.5">
            <button
              onClick={() => setModo("kanban")}
              className={classNames("rounded-md px-3 py-1 text-xs font-medium", modo === "kanban" ? "bg-stone-900 text-white" : "text-stone-500")}
            >
              Kanban
            </button>
            <button
              onClick={() => setModo("tabela")}
              className={classNames("rounded-md px-3 py-1 text-xs font-medium", modo === "tabela" ? "bg-stone-900 text-white" : "text-stone-500")}
            >
              Tabela
            </button>
          </div>
          <button
            onClick={() => setModalNovoAberto(true)}
            className="inline-flex items-center gap-1.5 rounded-lg bg-stone-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-stone-800"
          >
            <Plus className="h-3.5 w-3.5" /> Novo item
          </button>
        </div>
      </div>

      <FiltrosMatriz filtros={filtros} setFiltros={setFiltros} aberta={filtrosAbertos} setAberta={setFiltrosAbertos} />

      {modo === "kanban" ? (
        <div className="flex gap-3 overflow-x-auto pb-2">
          {STATUS_COLUNAS.map((status) => (
            <ColunaKanban
              key={status}
              status={status}
              documentos={ordenados.filter((d) => d.status === status)}
              onClickDoc={onClickDoc}
              onDrop={onMoveStatus}
            />
          ))}
        </div>
      ) : (
        <div className="overflow-x-auto rounded-xl border border-stone-200 bg-white">
          <table className="w-full">
            <thead>
              <tr className="border-b border-stone-200 bg-stone-50">
                {colunasTabela.map((c) => (
                  <th
                    key={c.rotulo}
                    onClick={() => c.campo && alternarOrdenacao(c.campo)}
                    className={classNames(
                      "px-3 py-2 text-left text-[11px] font-semibold uppercase tracking-wide text-stone-500",
                      c.campo && "cursor-pointer hover:text-stone-800"
                    )}
                  >
                    {c.rotulo}
                    {sort.campo === c.campo && (sort.dir === 1 ? " ↑" : " ↓")}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {ordenados.map((doc) => (
                <LinhaTabela key={doc.id} doc={doc} onClick={() => onClickDoc(doc.id)} />
              ))}
            </tbody>
          </table>
          {ordenados.length === 0 && <p className="p-6 text-center text-xs text-stone-400">Nenhum documento encontrado com esses filtros.</p>}
        </div>
      )}

      {modalNovoAberto && (
        <ModalNovoDocumento
          onClose={() => setModalNovoAberto(false)}
          onSalvar={(dados) => {
            onCriarDocumento(dados);
            setModalNovoAberto(false);
          }}
        />
      )}
    </div>
  );
}

function ModalNovoDocumento({ onClose, onSalvar }) {
  const [form, setForm] = useState({
    nome: "",
    tipo: TIPOS_DOCUMENTO[0].atual,
    classificacao: "Governança",
    area: AREAS[0],
    pilar: PILARES[0].nome,
    prioridade: "Média",
    risco: "Médio",
  });

  return (
    <Modal titulo="Novo item da Matriz de Controle" onClose={onClose}>
      <div className="space-y-3">
        <Campo label="Nome do documento">
          <input className={inputCls} value={form.nome} onChange={(e) => setForm({ ...form, nome: e.target.value })} placeholder="Ex.: Diretriz de Privacidade" />
        </Campo>
        <div className="grid grid-cols-2 gap-3">
          <Campo label="Tipo">
            <select className={inputCls} value={form.tipo} onChange={(e) => setForm({ ...form, tipo: e.target.value })}>
              {TIPOS_DOCUMENTO.map((t) => (
                <option key={t.atual} value={t.atual}>
                  {t.atual}
                </option>
              ))}
            </select>
          </Campo>
          <Campo label="Classificação">
            <select className={inputCls} value={form.classificacao} onChange={(e) => setForm({ ...form, classificacao: e.target.value })}>
              {["Governança", "Tático", "Operacional"].map((c) => (
                <option key={c} value={c}>
                  {c}
                </option>
              ))}
            </select>
          </Campo>
          <Campo label="Área responsável">
            <select className={inputCls} value={form.area} onChange={(e) => setForm({ ...form, area: e.target.value })}>
              {AREAS.map((a) => (
                <option key={a} value={a}>
                  {a}
                </option>
              ))}
            </select>
          </Campo>
          <Campo label="Pilar da trilha">
            <select className={inputCls} value={form.pilar} onChange={(e) => setForm({ ...form, pilar: e.target.value })}>
              {PILARES.map((p) => (
                <option key={p.nome} value={p.nome}>
                  {p.nome}
                </option>
              ))}
            </select>
          </Campo>
          <Campo label="Prioridade">
            <select className={inputCls} value={form.prioridade} onChange={(e) => setForm({ ...form, prioridade: e.target.value })}>
              {["Alta", "Média", "Baixa"].map((p) => (
                <option key={p} value={p}>
                  {p}
                </option>
              ))}
            </select>
          </Campo>
          <Campo label="Classificação de risco">
            <select className={inputCls} value={form.risco} onChange={(e) => setForm({ ...form, risco: e.target.value })}>
              {["Alto", "Médio", "Baixo"].map((r) => (
                <option key={r} value={r}>
                  {r}
                </option>
              ))}
            </select>
          </Campo>
        </div>
        <div className="flex justify-end gap-2 pt-2">
          <button onClick={onClose} className="rounded-lg px-3 py-1.5 text-xs font-medium text-stone-500 hover:bg-stone-100">
            Cancelar
          </button>
          <button
            disabled={!form.nome.trim()}
            onClick={() => onSalvar(form)}
            className="rounded-lg bg-stone-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-stone-800 disabled:opacity-40"
          >
            Criar item
          </button>
        </div>
      </div>
    </Modal>
  );
}

