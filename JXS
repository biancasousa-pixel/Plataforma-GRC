                <dd className="text-stone-600">{t.frequencia}</dd>
                <dt className="text-stone-400">Duração</dt>
                <dd className="text-stone-600">{t.duracao}</dd>
                <dt className="text-stone-400">Evidência</dt>
                <dd className="text-stone-600">{t.evidencia}</dd>
                {t.fonteExterna && (
                  <>
                    <dt className="text-stone-400">Fonte</dt>
