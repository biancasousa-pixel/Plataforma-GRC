/* ----------------------------- canal de denúncias / gestão de casos ----------------------------- */

function CartaoCaso({ caso, slaConfig, onClick }) {
  const prazo = calcularPrazoCaso(caso, slaConfig);
  const dias = diasAte(prazo);
  const emAberto = !["Concluída", "Arquivada"].includes(caso.status);
  return (
    <div
      draggable
      onDragStart={(e) => e.dataTransfer.setData("text/plain", caso.id)}
      onClick={onClick}
      className="cursor-pointer rounded-lg border border-stone-200 bg-white p-3 shadow-sm hover:border-stone-300 hover:shadow"
    >
      <div className="mb-1.5 flex items-center justify-between">
        <Tag tone="neutral">{caso.categoria}</Tag>
        <Dot tone={gravidadeTone(caso.gravidade)} />
      </div>
      <p className="text-xs font-medium text-stone-800">{caso.protocolo}</p>
      <p className="mt-1 text-[11px] text-stone-500">{caso.canalOrigem}</p>
      <div className="mt-2 flex items-center justify-between">
        <Tag tone="neutral">{caso.areaRelacionada || "—"}</Tag>
        {caso.responsavelInvestigacao ? <Avatares nomes={[caso.responsavelInvestigacao]} /> : <span className="text-[11px] text-stone-400">Sem investigador</span>}
      </div>
      {emAberto && dias !== null && (
        <p className={classNames("mt-2 flex items-center gap-1 text-[11px] font-medium", dias < 0 ? "text-red-600" : dias <= 5 ? "text-amber-600" : "text-stone-400")}>
          <AlertTriangle className="h-3 w-3" /> {dias < 0 ? `prazo vencido há ${Math.abs(dias)}d` : `prazo em ${dias}d`}
        </p>
      )}
    </div>
  );
}

function ColunaKanbanCasos({ status, casos, slaConfig, onClickCaso, onDrop }) {
  return (
    <div
      onDragOver={(e) => e.preventDefault()}
      onDrop={(e) => {
        const id = e.dataTransfer.getData("text/plain");
        onDrop(id, status);
      }}
      className="flex min-h-[180px] w-64 shrink-0 flex-col rounded-xl bg-stone-100/60 p-2"
    >
      <div className="mb-2 flex items-center justify-between px-1">
        <h3 className="text-xs font-semibold uppercase tracking-wide text-stone-500">{status}</h3>
        <span className="text-xs text-stone-400">{casos.length}</span>
      </div>
      <div className="space-y-2">
        {casos.map((c) => (
          <CartaoCaso key={c.id} caso={c} slaConfig={slaConfig} onClick={() => onClickCaso(c.id)} />
        ))}
      </div>
    </div>
  );
}

function Casos({ casos, slaConfig, busca, onClickCaso, onMoveStatus, onCriarCaso }) {
  const [filtros, setFiltros] = useState({ categoria: "", canalOrigem: "", gravidade: "" });
  const [filtrosAbertos, setFiltrosAbertos] = useState(false);
  const [modalNovoAberto, setModalNovoAberto] = useState(false);

  const filtrados = useMemo(() => {
    return casos.filter((c) => {
      if (busca && !`${c.protocolo} ${c.categoria}`.toLowerCase().includes(busca.toLowerCase())) return false;
      if (filtros.categoria && c.categoria !== filtros.categoria) return false;
      if (filtros.canalOrigem && c.canalOrigem !== filtros.canalOrigem) return false;
      if (filtros.gravidade && c.gravidade !== filtros.gravidade) return false;
      return true;
    });
  }, [casos, busca, filtros]);

  const abertos = casos.filter((c) => !["Concluída", "Arquivada"].includes(c.status));
  const dentroPrazo = abertos.filter((c) => {
    const dias = diasAte(calcularPrazoCaso(c, slaConfig));
    return dias === null || dias >= 0;
  });
  const pctSla = abertos.length ? Math.round((dentroPrazo.length / abertos.length) * 100) : null;

  const concluidos = casos.filter((c) => c.status === "Concluída" && c.dataConclusao);
  const tempoMedio = concluidos.length
    ? Math.round(concluidos.reduce((acc, c) => acc + (new Date(c.dataConclusao) - new Date(c.dataRecebimento)) / 86400000, 0) / concluidos.length)
    : null;

  const ultimos30 = casos.filter((c) => {
    const dias = diasAte(c.dataRecebimento);
    return dias !== null && Math.abs(dias) <= 30;
  }).length;

  const porCanal = painelContagem(casos, "canalOrigem", CANAIS_ORIGEM);
  const porStatusList = painelContagem(casos, "status", STATUS_CASOS);

  return (
    <div className="mx-auto max-w-6xl">
      <div className="mb-4 flex flex-wrap items-start justify-between gap-3">
        <div>
          <h1 className="text-lg font-semibold text-stone-900">Canal de Denúncias</h1>
          <p className="text-xs text-stone-500">Acompanhamento caso a caso, com prazo de resposta por categoria.</p>
        </div>
        <button
          onClick={() => setModalNovoAberto(true)}
          className="inline-flex items-center gap-1.5 rounded-lg bg-stone-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-stone-800"
        >
          <Plus className="h-3.5 w-3.5" /> Registrar caso
        </button>
      </div>

      <div className="mb-5 rounded-xl border border-amber-200 bg-amber-50 p-4 text-xs leading-relaxed text-amber-800">
        <strong className="font-semibold">Nota de arquitetura:</strong> em produção, este módulo deveria nascer com a
        trava de acesso ligada (Admin/Comitê GRC + responsável do caso) — a única exceção deliberada à regra de "todos
        veem tudo" da Fase 1 (ver seção B.5 do documento de arquitetura). Neste protótipo, por ser uma demonstração
        compartilhada, todos veem todos os casos.
      </div>

      <div className="mb-5 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <KpiCard
          label="Casos abertos"
          valor={abertos.length}
          sublabel={`${casos.length} no total`}
          tone={casos.length === 0 ? "neutral" : abertos.length === 0 ? "green" : "neutral"}
        />
        <KpiCard
          label="Dentro do prazo (SLA)"
          valor={pctSla === null ? "—" : `${pctSla}%`}
          sublabel={abertos.length ? `${dentroPrazo.length}/${abertos.length} casos abertos` : "Sem casos abertos"}
          tone={pctSla === null ? "neutral" : pctSla >= 70 ? "green" : pctSla >= 30 ? "amber" : "red"}
        />
        <KpiCard
          label="Tempo médio de resolução"
          valor={tempoMedio === null ? "—" : `${tempoMedio}d`}
          sublabel={concluidos.length ? `${concluidos.length} caso(s) concluído(s)` : "Nenhum caso concluído ainda"}
          tone="neutral"
        />
        <KpiCard label="Casos nos últimos 30 dias" valor={ultimos30} sublabel="Volume recente" tone="neutral" />
      </div>

      <div className="mb-5 grid grid-cols-1 gap-4 lg:grid-cols-2">
        <ListaContagem titulo="Por canal de origem — como identificamos" dados={porCanal} />
        <ListaContagem titulo="Por etapa — como estamos seguindo" dados={porStatusList} />
      </div>

      <button
        onClick={() => setFiltrosAbertos(!filtrosAbertos)}
        className="mb-2 flex items-center gap-1.5 text-xs font-medium text-stone-500 hover:text-stone-800"
      >
        <ChevronDown className={classNames("h-3.5 w-3.5 transition-transform", filtrosAbertos && "rotate-180")} />
        Filtros
      </button>
      {filtrosAbertos && (
        <div className="mb-3 flex flex-wrap gap-2">
          <select
            value={filtros.categoria}
            onChange={(e) => setFiltros({ ...filtros, categoria: e.target.value })}
            className="rounded-lg border border-stone-300 bg-white px-2.5 py-1 text-xs text-stone-600"
          >
            <option value="">Categoria: todas</option>
            {CATEGORIAS_CASO.map((c) => (
              <option key={c} value={c}>
                {c}
              </option>
            ))}
          </select>
          <select
            value={filtros.canalOrigem}
            onChange={(e) => setFiltros({ ...filtros, canalOrigem: e.target.value })}
            className="rounded-lg border border-stone-300 bg-white px-2.5 py-1 text-xs text-stone-600"
          >
            <option value="">Canal: todos</option>
            {CANAIS_ORIGEM.map((c) => (
              <option key={c} value={c}>
                {c}
              </option>
            ))}
          </select>
          <select
            value={filtros.gravidade}
            onChange={(e) => setFiltros({ ...filtros, gravidade: e.target.value })}
            className="rounded-lg border border-stone-300 bg-white px-2.5 py-1 text-xs text-stone-600"
          >
            <option value="">Gravidade: todas</option>
            {GRAVIDADES.map((g) => (
              <option key={g} value={g}>
                {g}
              </option>
            ))}
          </select>
        </div>
      )}

      <div className="flex gap-3 overflow-x-auto pb-2">
        {STATUS_CASOS.map((status) => (
          <ColunaKanbanCasos
            key={status}
            status={status}
            casos={filtrados.filter((c) => c.status === status)}
            slaConfig={slaConfig}
            onClickCaso={onClickCaso}
            onDrop={onMoveStatus}
          />
        ))}
      </div>

      {casos.length === 0 && (
        <p className="mt-4 text-center text-xs text-stone-400">
          Nenhum caso registrado ainda. Quando o comitê começar a registrar relatos recebidos, eles aparecem aqui com
          prazo de resposta e linha do tempo de andamento.
        </p>
      )}

      {modalNovoAberto && (
        <ModalNovoCaso
          onClose={() => setModalNovoAberto(false)}
          onSalvar={(dados) => {
            onCriarCaso(dados);
            setModalNovoAberto(false);
          }}
        />
      )}
    </div>
  );
}

